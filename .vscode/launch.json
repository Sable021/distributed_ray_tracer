{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "Ray Tracer",
      "request": "launch",
      "mainClass": "com.raytracer.Main",
      "cwd": "${workspaceFolder}",
      "console": "internalConsole"
